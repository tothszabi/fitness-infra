DB_NAME=wordpress_db
DB_USER=wp_user
DB_PASSWORD=replace_me_with_secure_password
DB_ROOT_PASSWORD=replace_me_with_secure_root_password

AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
S3_ENDPOINT=https://replace_me.r2.cloudflarestorage.com
S3_BUCKET=s3://replace-me-bucket

# Dozzle Log Viewer Credentials
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=replace_me_with_secure_password

# Grafana Cloud (grafana.com → My Account → Stack → Details)
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USER=replace_me_with_numeric_id
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=replace_me_with_numeric_id
GRAFANA_CLOUD_API_KEY=glc_replace_me
